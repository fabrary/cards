{
  "name": "@flesh-and-blood/root",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "lerna run build",
    "clean:csvs": "ts-node --project packages/cards/tsconfig.json scripts/check-redundancy.ts",
    "prefull": "npm run update:dependencies",
    "full": "lerna run full",
    "ncu": "lerna exec ncu",
    "publish": "npm login && lerna publish",
    "publish:legacy": "npm login --auth-type=legacy && lerna publish",
    "test": "lerna run test",
    "typecheck": "lerna run typecheck",
    "update:dependencies": "lerna run update:dependencies",
    "update:snapshots": "lerna run update:snapshots"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "lerna": "^8.0.1"
  }
}
