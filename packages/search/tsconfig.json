{
  "compilerOptions": {
    "emitDeclarationOnly": true,
    "esModuleInterop": true,
    "declaration": true,
    "isolatedModules": true,
    "lib": ["ES2021"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "target": "ES6"
  },
  "include": ["src"]
}
