{
  "name": "@flesh-and-blood/search",
  "description": "TypeScript search engine for Flesh and Blood cards",
  "version": "4.0.25",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./abbreviations": {
      "types": "./dist/abbreviations.d.ts",
      "import": "./dist/abbreviations.js"
    },
    "./shorthands": {
      "types": "./dist/shorthands.d.ts",
      "import": "./dist/shorthands.js"
    },
    "./memes": {
      "types": "./dist/memes.d.ts",
      "import": "./dist/memes.js"
    }
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "esbuild src/*.ts --outdir=dist --format=esm --platform=neutral --target=es2020",
    "build:cjs": "esbuild src/index.ts --outfile=dist/index.cjs --bundle --minify --format=cjs --platform=node --target=es2020 --external:@flesh-and-blood/types --external:fuse.js",
    "postbuild": "tsc --declaration && npm test",
    "test": "jest",
    "test:specific": "jest -t 'Matching printing from treatment'",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "full": "npm i && npm run build"
  },
  "dependencies": {
    "fuse.js": "^6.6.2"
  },
  "peerDependencies": {
    "@flesh-and-blood/types": "^4.0.0"
  },
  "devDependencies": {
    "@flesh-and-blood/cards": "file:../cards",
    "@flesh-and-blood/types": "^4.0.22",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "esbuild": "^0.19.10",
    "esbuild-jest": "^0.5.0",
    "jest": "^29.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "files": [
    "/dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fabrary/fab-cards.git"
  },
  "bugs": {
    "url": "https://github.com/fabrary/fab-cards/issues"
  },
  "homepage": "https://github.com/fabrary/fab-cards#readme",
  "author": "Phillip Manwaring",
  "license": "MIT",
  "keywords": [
    "Flesh and Blood",
    "FAB",
    "FABTCG"
  ],
  "gitHead": "621a4ccc12f40d351b1ca49bcc7ea8a83ca15310"
}
